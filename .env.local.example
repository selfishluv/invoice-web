# PostgreSQL 연결 설정
DATABASE_URL=             # PostgreSQL 연결 문자열 (예: postgresql://user:pass@host:5432/dbname)

# On-demand Revalidation (선택)
REVALIDATE_SECRET=        # POST /api/revalidate?secret=<값> 호출 시 사용하는 임의 시크릿

# 사이트 URL (sitemap/robots 생성용, 선택)
NEXT_PUBLIC_SITE_URL=     # 예: https://aitime.vercel.app
